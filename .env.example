APP_NAME="HostelEase"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hostelease
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

HOSTELEASE_DEFAULT_COUNTRY_CODE="+91"
HOSTELEASE_SESSION_TIMEOUT=30
HOSTELEASE_SUBSCRIPTION_AMOUNT=5000

DB_DUMP_BINARY=mysqldump

SUPERADMIN_NAME="Super Admin"
SUPERADMIN_MOBILE="9999999999"
SUPERADMIN_EMAIL="admin@satvscript.com"
SUPERADMIN_PASSWORD="password"

SETUP_TOKEN=

WHATSAPP_ENABLED=false
RAZORPAY_ENABLED=true
PAYU_ENABLED=false

VITE_APP_NAME="${APP_NAME}"

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
HOSTELEASE_PRICE_YEARLY=20000
HOSTELEASE_PRICE_MONTHLY=2000
HOSTELEASE_FREE_PER_BRANCHES=3
RAZORPAY_WEBHOOK_SECRET=
